# LLM — provider-agnostisk, OpenAI-kompatibel endpoint (inget hårdkodat)
LLM_BASE_URL=https://<host>/v1
LLM_API_KEY=<din-nyckel>
LLM_MODEL=<modellsträng>
# LLM_PROXY=http://<proxy>            # valfri
# LLM_PARAMS={"temperature": 0}       # valfri, extra body-parametrar som JSON

# MCP-server (MVP: en server; PRD beskriver flera via config)
MCP_URL=http://127.0.0.1:8000/mcp
MCP_KEY=<mcp-bearer-nyckel>

# Systemprompt (valfritt — annars --system <fil> eller inbyggd default)
# MCP_CHAT_SYSTEM_FILE=prompts/min-skill.md
